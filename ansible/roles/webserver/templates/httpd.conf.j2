# Managed by Ansible – do not edit manually
# Template: roles/webserver/templates/httpd.conf.j2

ServerRoot "/etc/httpd"
Listen {{ webserver_http_port }}

# Load core modules
Include conf.modules.d/*.conf

User apache
Group apache

ServerAdmin root@localhost
ServerName {{ webserver_server_name }}

# Deny access to the entire filesystem by default
<Directory />
    AllowOverride none
    Require all denied
</Directory>

# Document root
DocumentRoot "{{ webserver_document_root }}"

<Directory "{{ webserver_document_root }}">
    Options Indexes FollowSymLinks
    AllowOverride None
    Require all granted
</Directory>

<IfModule dir_module>
    DirectoryIndex index.html index.htm
</IfModule>

<Files ".ht*">
    Require all denied
</Files>

ErrorLog  "{{ webserver_log_dir }}/error_log"
LogLevel  warn

<IfModule log_config_module>
    LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\"" combined
    LogFormat "%h %l %u %t \"%r\" %>s %b" common
    CustomLog "{{ webserver_log_dir }}/access_log" combined
</IfModule>

<IfModule mime_module>
    TypesConfig /etc/mime.types
    AddType application/x-compress .Z
    AddType application/x-gzip .gz .tgz
</IfModule>

# Reverse proxy to demo app
<IfModule mod_proxy.c>
    ProxyPreserveHost On
    ProxyPass        /app/ http://localhost:{{ demo_service_port }}/
    ProxyPassReverse /app/ http://localhost:{{ demo_service_port }}/
</IfModule>

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Hide server version
ServerTokens Prod
ServerSignature Off

IncludeOptional conf.d/*.conf
